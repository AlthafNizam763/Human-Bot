rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to verify user authentication
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if resource belongs to owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Settings Collection rules
    match /settings/{settingId} {
      // Matches settings, connection, and bot status docs
      allow read, write: if isAuthenticated() && (
        settingId == request.auth.uid || 
        settingId == request.auth.uid + "_connection" ||
        settingId == request.auth.uid + "_botStatus"
      );
    }
    
    // Contacts Collection rules
    match /contacts/{contactId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Messages Collection rules
    match /messages/{messageId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Personalities Collection rules
    match /personalities/{personalityId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // System logs Collection rules
    match /logs/{logId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
